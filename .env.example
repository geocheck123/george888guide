# --- Telegram ---
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
CHANNEL_ID=-1001234567890

# --- Webhook ---
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook/telegram
LAVA_WEBHOOK_PATH=/webhook/lava
WEBHOOK_PORT=8080

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=subscriptions
POSTGRES_USER=bot
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql+asyncpg://bot:strong_password_here@db:5432/subscriptions

# --- Lava.top ---
# Your API key from: lava.top → Integrations → Public API → Create API key
LAVA_API_KEY=your_lava_api_key_here

# A secret string YOU invent (any random string, e.g. a UUID).
# Paste this same value into the lava.top webhook settings as the "API Key".
# Lava.top will send it back in the X-Api-Key header with every webhook.
LAVA_WEBHOOK_SECRET=your_random_webhook_secret_here

LAVA_API_URL=https://api.lava.top

# --- Subscription plans (price in RUB) ---
PLAN_1_MONTH_PRICE=299
PLAN_3_MONTH_PRICE=799
PLAN_12_MONTH_PRICE=2499

# --- Misc ---
LOG_LEVEL=INFO
