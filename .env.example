# ─── Telegram ───────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321          # comma-separated Telegram user IDs
CHANNEL_ID=-1001234567890              # private channel / supergroup ID

# ─── Webhook ────────────────────────────────────────────────────────────────
WEBHOOK_HOST=https://yourdomain.com    # public HTTPS domain
WEBHOOK_PATH=/webhook/telegram         # path Telegram will call
LAVA_WEBHOOK_PATH=/webhook/lava        # path Lava.top will call
WEBHOOK_PORT=8080                      # internal port the app listens on

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=subscriptions
POSTGRES_USER=bot
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql+asyncpg://bot:strong_password_here@db:5432/subscriptions

# ─── Lava.top ───────────────────────────────────────────────────────────────
LAVA_SECRET_KEY=your_lava_secret_key
LAVA_SHOP_ID=your_lava_shop_id
LAVA_API_URL=https://api.lava.top/business/invoice/create

# ─── Subscription plans (price in RUB) ─────────────────────────────────────
PLAN_1_MONTH_PRICE=299
PLAN_3_MONTH_PRICE=799
PLAN_12_MONTH_PRICE=2499

# ─── Misc ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
